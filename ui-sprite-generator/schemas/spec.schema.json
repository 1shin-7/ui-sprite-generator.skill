{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI Sprite Spec",
  "type": "object",
  "required": ["schema_version", "source_image", "style", "background", "components", "instances"],
  "properties": {
    "schema_version": { "const": "1.2" },
    "source_image": {
      "type": "object",
      "required": ["path", "width", "height"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "style": {
      "type": "object",
      "required": [
        "description",
        "ui_style",
        "background_style",
        "palette",
        "materials",
        "lighting",
        "ornament_language",
        "negative_constraints"
      ],
      "properties": {
        "description": { "type": "string" },
        "ui_style": { "type": "string" },
        "background_style": { "type": "string" },
        "palette": { "type": "array", "items": { "type": "string" } },
        "materials": { "type": "array", "items": { "type": "string" } },
        "lighting": { "type": "string" },
        "ornament_language": { "type": "string" },
        "negative_constraints": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "required": ["description", "visible_regions", "occluded_regions", "mask_strategy"],
      "properties": {
        "description": { "type": "string" },
        "visible_regions": { "type": "array", "items": { "$ref": "#/$defs/region" } },
        "occluded_regions": {
          "type": "array",
          "items": {
            "allOf": [{ "$ref": "#/$defs/region" }],
            "properties": {
              "occluded_by": { "type": "array", "items": { "type": "string" } },
              "inpaint_hint": { "type": "string" }
            }
          }
        },
        "mask_strategy": { "type": "string" }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    },
    "instances": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instance" }
    }
  },
  "$defs": {
    "bbox": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "size": {
      "type": "object",
      "required": ["w", "h"],
      "properties": {
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "region": {
      "type": "object",
      "required": ["id", "bbox"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
        "bbox": { "$ref": "#/$defs/bbox" }
      },
      "additionalProperties": true
    },
    "component": {
      "type": "object",
      "required": [
        "id",
        "role",
        "visual_description",
        "attached_decorations",
        "center",
        "surface_policy",
        "occlusion",
        "render_pattern",
        "resolution_policy",
        "atlas_policy",
        "states",
        "companions"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "role": { "type": "string" },
        "visual_description": { "type": "string" },
        "attached_decorations": { "type": "array", "items": { "type": "string" } },
        "center": { "enum": ["hollow", "filled", "transparent", "n/a"] },
        "surface_policy": { "enum": ["flat_fill", "textured_fill", "hollow", "transparent", "n/a"] },
        "occlusion": {
          "type": "object",
          "required": ["status", "occluders", "reconstruction"],
          "properties": {
            "status": { "enum": ["unoccluded", "partially_occluded"] },
            "occluders": { "type": "array", "items": { "type": "string" } },
            "reconstruction": { "type": "string" }
          },
          "additionalProperties": false
        },
        "render_pattern": {
          "enum": ["background_image", "nine_slice", "linear_clip", "radial_clip", "tiled_repeat", "overlay_stack"]
        },
        "render_params": { "type": "object" },
        "resolution_policy": {
          "type": "object",
          "required": ["minimum_source_scale", "recommended_generation_scale", "target_px", "allow_downscale"],
          "properties": {
            "minimum_source_scale": { "type": "number", "minimum": 1 },
            "recommended_generation_scale": { "type": "number", "minimum": 1 },
            "target_px": {
              "type": "object",
              "required": ["w", "h"],
              "properties": {
                "w": { "type": "integer", "minimum": 1 },
                "h": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            },
            "allow_downscale": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "atlas_policy": {
          "type": "object",
          "required": ["group", "can_share_sheet", "minimum_gutter"],
          "properties": {
            "group": { "type": "string" },
            "can_share_sheet": { "type": "boolean" },
            "minimum_gutter": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "states": { "type": "array", "items": { "type": "string" } },
        "companions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "layering": {
      "type": "object",
      "required": ["z_index", "anchor"],
      "properties": {
        "z_index": { "type": "integer" },
        "anchor": { "enum": ["top_left"] }
      },
      "additionalProperties": false
    },
    "instance": {
      "type": "object",
      "required": ["id", "uses", "source_bbox", "layering"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "uses": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "source_bbox": { "$ref": "#/$defs/bbox" },
        "layering": { "$ref": "#/$defs/layering" },
        "display_size": { "$ref": "#/$defs/size" },
        "render_params_override": { "type": "object" },
        "rendered": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
